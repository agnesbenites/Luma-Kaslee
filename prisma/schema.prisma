generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Escola {
  id        String    @id @default(cuid())
  nome      String
  email     String    @unique
  senhaHash String
  cnpj      String?   @unique
  cidade    String?
  estado    String?
  turmas    Turma[]
  convites  Convite[]
  criadoEm  DateTime  @default(now())
}

model Convite {
  id       String   @id @default(cuid())
  token    String   @unique @default(cuid())
  tipo     String
  email    String?
  usado    Boolean  @default(false)
  expiraEm DateTime
  escola   Escola   @relation(fields: [escolaId], references: [id])
  escolaId String
  criadoEm DateTime @default(now())
}

model Turma {
  id                  String              @id @default(cuid())
  nome                String
  serie               String
  turno               String?
  escola              Escola              @relation(fields: [escolaId], references: [id])
  escolaId            String
  professor           Professor           @relation(fields: [professorId], references: [id])
  professorId         String
  alunos              Aluno[]
  sessoes             Sessao[]
  familias            Familia[]
  atividadesAgendadas AtividadeAgendada[]
  gradeHoraria        GradeHoraria[]
}

model Professor {
  id                  String              @id @default(cuid())
  nome                String
  email               String              @unique
  senhaHash           String
  turmas              Turma[]
  materiais           Material[]
  atividadesAgendadas AtividadeAgendada[]
  criadoEm            DateTime            @default(now())
  materias  String[] @default([])
  anos      String[] @default([])

}

model Aluno {
  id                   String                @id @default(cuid())
  nome                 String
  email                String                @unique
  senhaHash            String
  turma                Turma                 @relation(fields: [turmaId], references: [id])
  turmaId              String
  respostas            Resposta[]
  interacoes           Interacao[]
  perfilCognitivo      PerfilCognitivo?
  familias             Familia[]
  progressosHabilidade ProgressoHabilidade[]
  consentimentoLgpd    Boolean               @default(false)
  responsavelNome      String?
  responsavelEmail     String?
  criadoEm             DateTime              @default(now())
}

model Familia {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senhaHash String
  aluno     Aluno    @relation(fields: [alunoId], references: [id])
  alunoId   String
  turma     Turma    @relation(fields: [turmaId], references: [id])
  turmaId   String
  criadoEm  DateTime @default(now())
}

model HabilidadeBNCC {
  id         String                @id @default(cuid())
  codigo     String                @unique
  descricao  String
  componente String
  serie      String
  etapa      String
  area       String
  sessoes    SessaoBNCC[]
  progressos ProgressoHabilidade[]
}

model SessaoBNCC {
  id           String         @id @default(cuid())
  sessao       Sessao         @relation(fields: [sessaoId], references: [id])
  sessaoId     String
  habilidade   HabilidadeBNCC @relation(fields: [habilidadeId], references: [id])
  habilidadeId String
}

model Material {
  id          String    @id @default(cuid())
  titulo      String
  tipo        String
  conteudo    String
  fileUrl     String?
  filePath    String?
  fileMime    String?
  fileTamanho Int?
  componente  String?
  serie       String?
  professor   Professor @relation(fields: [professorId], references: [id])
  professorId String
  sessoes     Sessao[]
  criadoEm    DateTime  @default(now())
}

model Sessao {
  id                  String              @id @default(cuid())
  titulo              String
  ancora              String
  status              String              @default("RASCUNHO")
  metodo              String              @default("SOCRATICO")
  metodoJustificativa String?
  turma               Turma               @relation(fields: [turmaId], references: [id])
  turmaId             String
  material            Material?           @relation(fields: [materialId], references: [id])
  materialId          String?
  habilidades         SessaoBNCC[]
  respostas           Resposta[]
  interacoes          Interacao[]
  agendamentos        AtividadeAgendada[]
  gradeHoraria        GradeHoraria[]
  criadoEm            DateTime            @default(now())
  encerradaEm         DateTime?
}

model Resposta {
  id              String   @id @default(cuid())
  aluno           Aluno    @relation(fields: [alunoId], references: [id])
  alunoId         String
  sessao          Sessao   @relation(fields: [sessaoId], references: [id])
  sessaoId        String
  pergunta        String
  texto           String
  tempoEscrita    Int
  turno           Int
  alinhamentoBNCC Float?
  sinalEmocional  String?
  criadoEm        DateTime @default(now())
}

model Interacao {
  id        String   @id @default(cuid())
  aluno     Aluno    @relation(fields: [alunoId], references: [id])
  alunoId   String
  sessao    Sessao   @relation(fields: [sessaoId], references: [id])
  sessaoId  String
  resumo    String?
  historico String?
  criadoEm  DateTime @default(now())

  @@unique([alunoId, sessaoId])
}

model PerfilCognitivo {
  id             String   @id @default(cuid())
  aluno          Aluno    @relation(fields: [alunoId], references: [id])
  alunoId        String   @unique
  tipoRaciocinio String?
  areaAfinidade  String?
  indiceFoco     Float?
  alertaAtivo    Boolean  @default(false)
  atualizadoEm   DateTime @updatedAt
}

model ProgressoHabilidade {
  id           String         @id @default(cuid())
  aluno        Aluno          @relation(fields: [alunoId], references: [id])
  alunoId      String
  habilidade   HabilidadeBNCC @relation(fields: [habilidadeId], references: [id])
  habilidadeId String
  status       String         @default("NAO_INICIADA")
  evidencias   Int            @default(0)
  atualizadoEm DateTime       @updatedAt

  @@unique([alunoId, habilidadeId])
}

model AtividadeAgendada {
  id           String    @id @default(cuid())
  titulo       String
  descricao    String?
  data         DateTime
  status       String    @default("PLANEJADA")
  turma        Turma     @relation(fields: [turmaId], references: [id])
  turmaId      String
  professor    Professor @relation(fields: [professorId], references: [id])
  professorId  String
  sessao       Sessao?   @relation(fields: [sessaoId], references: [id])
  sessaoId     String?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
}

model GradeHoraria {
  id           String   @id @default(cuid())
  turma        Turma    @relation(fields: [turmaId], references: [id])
  turmaId      String
  diaSemana    Int
  horaInicio   String
  horaFim      String
  componente   String
  fixo         Boolean  @default(true)
  sessao       Sessao?  @relation(fields: [sessaoId], references: [id])
  sessaoId     String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}
